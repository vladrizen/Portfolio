---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with InalhaSoft - questions, feedback, collaborations, and more.">
  <!-- Hero -->
  <section class="py-20 bg-gradient-to-br from-[#ff2d95]/10 to-[#00d4ff]/10">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">Get in Touch</h1>
      <p class="text-xl text-[#a0a0a0] max-w-3xl mx-auto">
        Have questions, feedback, or want to collaborate? We'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-20">
    <div class="container mx-auto px-6">
      <div class="max-w-2xl mx-auto">
        <div class="card">
          <!-- Formspree form - replace FORM_ID with actual Formspree form ID -->
          <form action="https://formspree.io/f/FORM_ID" method="POST" class="space-y-6">
            <div>
              <label for="name" class="block text-lg font-semibold mb-2">Name *</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/20 rounded-lg focus:outline-none focus:border-[#ff2d95] transition-colors"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="email" class="block text-lg font-semibold mb-2">Email *</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/20 rounded-lg focus:outline-none focus:border-[#ff2d95] transition-colors"
                placeholder="your@email.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-lg font-semibold mb-2">Subject *</label>
              <select 
                id="subject" 
                name="subject" 
                required
                class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/20 rounded-lg focus:outline-none focus:border-[#ff2d95] transition-colors"
              >
                <option value="" disabled selected>Select a subject</option>
                <option value="press">Press / Business Inquiry</option>
                <option value="support">Support</option>
                <option value="general">General</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-lg font-semibold mb-2">Message *</label>
              <textarea 
                id="message" 
                name="message" 
                required
                rows="6"
                class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/20 rounded-lg focus:outline-none focus:border-[#ff2d95] transition-colors resize-none"
                placeholder="Your message..."
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full text-lg py-4">
              Send Message
            </button>
          </form>

          <div class="mt-8 pt-8 border-t border-white/10">
            <p class="text-center text-[#a0a0a0] mb-4">Or reach us directly at:</p>
            <a href="mailto:info@inalha-soft.com" class="block text-center text-xl gradient-text font-semibold hover:opacity-80 transition-opacity">
              info@inalha-soft.com
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Links -->
  <section class="py-20 bg-[#121212]">
    <div class="container mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-8">Connect With Us</h2>
      <div class="flex flex-wrap justify-center gap-6">
        <a href="https://discord.gg/3hE5v6q4" target="_blank" rel="noopener noreferrer" class="card px-8 py-4 hover:border-[#ff2d95]/50 transition-colors">
          <span class="text-[#a0a0a0]">Discord</span>
        </a>
        <a href="https://x.com/InalhaSoft" target="_blank" rel="noopener noreferrer" class="card px-8 py-4 hover:border-[#ff2d95]/50 transition-colors">
          <span class="text-[#a0a0a0]">Twitter/X</span>
        </a>
        <a href="#" class="card px-8 py-4 opacity-50 cursor-not-allowed">
          <span class="text-[#a0a0a0]">LinkedIn (Coming Soon)</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
